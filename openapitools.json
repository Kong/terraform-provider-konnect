{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "6.2.1",
    "generators": {
      "identity-v3-client": {
        "generatorName": "typescript-axios",
        "output": "src/konnect/packages/identity/v3/npm/client",
        "glob": "computed/konnect/identity/v3/openapi.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      },
      "audit-logs-v2-client": {
        "generatorName": "typescript-axios",
        "output": "src/konnect/packages/audit-logs/v2/npm/client",
        "glob": "computed/konnect/audit-logs/v2/openapi.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      },

      "konnect-dev-client": {
        "generatorName": "typescript-axios",
        "output": "packages/konnect/dev/npm/client",
        "glob": "build/complete/konnect/dev.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      },
      "konnect-internal-client": {
        "generatorName": "typescript-axios",
        "output": "packages/konnect/internal/npm/client",
        "glob": "build/complete/konnect/internal.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      },
      "konnect-public-client": {
        "generatorName": "typescript-axios",
        "output": "packages/konnect/public/npm/client",
        "glob": "build/complete/konnect/public.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      },
      
      "portal-dev-client": {
        "generatorName": "typescript-axios",
        "output": "packages/portal/dev/npm/client",
        "glob": "build/complete/portal/dev.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      },
      "portal-internal-client": {
        "generatorName": "typescript-axios",
        "output": "packages/portal/internal/npm/client",
        "glob": "build/complete/portal/internal.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      },
      "portal-public-client": {
        "generatorName": "typescript-axios",
        "output": "packages/portal/public/npm/client",
        "glob": "build/complete/portal/public.yaml",
        "templateDir": "oas-generator-templates",
        "additionalProperties": {
          "modelPropertyNaming": "original",
          "useSingleRequestParameter": "true"
        }
      }
    }
  }
}
