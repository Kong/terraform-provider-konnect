{
  "name": "platform-api",
  "version": "1.0.0",
  "description": "Konnect Platform OpenAPI specs",
  "main": "index.js",
  "scripts": {
    "lint:all": "spectral lint '(portal|konnect)/definitions/**/openapi.yaml'",
    "generate-docs": "npm-run-all generate:*-docs",
    "generate:identity-v2-client": "rm -rf ./konnect/packages/identity/v2/npm/client && openapi-generator-cli generate --generator-key identity-v2-client",
    "generate:identity-v2-docs": "node ./tools/generate-docs-oas-file.js identity-v2 ./konnect/definitions/identity/v2/openapi.yaml",
    "validate:identity-v2-spec": "openapi-generator-cli validate -i ./konnect/definitions/identity/v2/openapi.yaml",
    "generate:organization-settings-v2-client": "rm -rf ./konnect/packages/organization-settings/v2/npm/client && openapi-generator-cli generate --generator-key organization-settings-v2-client",
    "generate:organization-settings-v2-docs": "node ./tools/generate-docs-oas-file.js organization-settings-v2 ./konnect/definitions/organization-settings/v2/openapi.yaml",
    "validate:organization-settings-v2-spec": "openapi-generator-cli validate -i ./konnect/definitions/organization-settings/v2/openapi.yaml",
    "generate:konnect-dev-client": "rm -rf ./packages/dev && openapi-generator-cli generate --generator-key konnect-dev-client",
    "generate:konnect-internal-client": "rm -rf ./packages/internal && openapi-generator-cli generate --generator-key konnect-internal-client",
    "generate:konnect-public-client": "rm -rf ./packages/public && openapi-generator-cli generate --generator-key konnect-public-client",
    "generate:portal-dev-client": "rm -rf ./packages/dev && openapi-generator-cli generate --generator-key portal-dev-client",
    "generate:portal-internal-client": "rm -rf ./packages/internal && openapi-generator-cli generate --generator-key portal-internal-client",
    "generate:portal-public-client": "rm -rf ./packages/public && openapi-generator-cli generate --generator-key portal-public-client",
    "generate:portal-rbac-v2-docs": "node ./tools/generate-docs-oas-file.js portal-rbac-v2 ./konnect/definitions/portal-rbac/v2/openapi.yaml",
    "generate:runtime-groups-v2-docs": "node ./tools/generate-docs-oas-file.js runtime-groups-v2 ./konnect/definitions/runtime-groups/v2/openapi.yaml",
    "generate:runtime-groups-config-v2-docs": "node ./tools/generate-docs-oas-file.js runtime-groups-config-v2 ./konnect/definitions/runtime-groups-config/v2/openapi.yaml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kong/platform-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Kong/platform-api/issues"
  },
  "homepage": "https://github.com/Kong/platform-api#readme",
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^9.1.0",
    "@openapitools/openapi-generator-cli": "^2.5.2",
    "@stoplight/spectral-cli": "^6.5.0",
    "fast-glob": "^3.2.12",
    "js-yaml": "^4.1.0",
    "mergician": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "redoc-cli": "^0.13.19",
    "traverse": "^0.6.7"
  }
}
