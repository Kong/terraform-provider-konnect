    {
      "src": "output/konnect/internal.yaml",
      "dest": "openapi.yaml"
    }
  ],
  "kong/sdk-konnect-js-dev": [
    {
      "src": "output/konnect/dev.yaml",
      "dest": "openapi.yaml"
    }
  ],
  "kong/sdk-portal-js": [
    {
      "src": "output/portal/public.yaml",
      "dest": "openapi.yaml"
    }
  ],
  "kong/khcp": [
