    {
      "src": "portal/definitions/portals/computed/openapi.yaml",
      "dest": "apps/portal-api/openapi/v2/portals/openapi.yaml"
    },
    {
      "src": "portal/definitions/products/computed/openapi.yaml",
      "dest": "apps/portal-api/openapi/v2/products/openapi.yaml"
    },
    {
      "src": "portal/definitions/registrations/computed/openapi.yaml",
      "dest": "apps/portal-api/openapi/v2/registrations/openapi.yaml"
    },
    {
      "src": "portal/definitions/search/computed/openapi.yaml",
      "dest": "apps/portal-api/openapi/v2/search/openapi.yaml"
    },
    {
      "src": "konnect/definitions/api-products/v2/computed/openapi.yaml",
      "dest": "apps/konnect-api/v2/api-products/openapi.yaml"
    }
